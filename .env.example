# STRM Watch 环境变量示例文件
# 复制此文件为 .env 后修改配置值

# 源文件夹路径（容器内部路径）
SOURCE_DIR=/source

# 目标文件夹路径（容器内部路径）
TARGET_DIR=/target

# 需要替换的旧路径前缀
# 例如：/CloudNAS/CloudDrive/115open/
OLD_KEYWORD=/CloudNAS/CloudDrive/115open/

# 替换后的新路径前缀
# 例如：/115/
NEW_MOUNT_PREFIX=/115/

# MediaServer 地址（可选，不需要通知功能可留空）
# 格式：http://ip:port 或 https://ip:port
MS_URL=

# MediaServer API Key（可选）
MS_API_KEY=

# 是否启用 URL 编码（True/False）
ENABLE_URL_ENCODE=True

# 时区设置（群晖 NAS 推荐设置为 Asia/Shanghai）
TZ=Asia/Shanghai
